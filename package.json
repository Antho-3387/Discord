{
  "name": "discord-clone",
  "version": "1.0.0",
  "description": "Une application web temps réel inspirée de Discord",
  "main": "server.js",
  "scripts": {
    "start": "node setup-schema.js && npm run db:push && node server.js",
    "dev": "nodemon server.js",
    "setup-db": "node setup-database.js",
    "configure": "node configure.js",
    "set-password": "node set-password.js",
    "migrate": "prisma migrate deploy",
    "db:push": "prisma db push --skip-generate --accept-data-loss || true",
    "postinstall": "prisma generate"
  },
  "keywords": [
    "discord",
    "chat",
    "websocket",
    "realtime"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "socket.io": "^4.6.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
